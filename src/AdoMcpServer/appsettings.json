{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  // HTTP mode listen URL (only used when running in HTTP mode)
  "Urls": "http://localhost:5100",
  // ─────────────────────────────────────────────────────────────────
  // Databases: list of pre-configured named database connections.
  // The LLM can also add connections at runtime using add_connection.
  // Supported DbType values: SqlServer | MySql | PostgreSql | Sqlite | Oracle
  // ─────────────────────────────────────────────────────────────────
  "Databases": [
    {
      "Name": "default",
      "DbType": "Sqlite",
      "ConnectionString": "Data Source=sample.db",
      "Description": "示例 SQLite 数据库（开发用途）"
    }
